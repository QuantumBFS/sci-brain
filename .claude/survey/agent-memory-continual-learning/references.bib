@inproceedings{Ge2025DynamicMixtureCurriculumLoRA,
  author    = {Ge, Chendi and Wang, Xin and Zhang, Zeyang and Chen, Hong and Fan, Jiapei and Huang, Longtao and Xue, Hui and Zhu, Wenwu},
  title     = {Dynamic Mixture of Curriculum {LoRA} Experts for Continual Multimodal Instruction Tuning},
  booktitle = {Proceedings of the 42nd International Conference on Machine Learning},
  year      = {2025},
  doi       = {10.48550/ARXIV.2506.11672},
  url       = {https://arxiv.org/abs/2506.11672},
  abstract  = {We propose D-MoLE, a Dynamic Mixture of Curriculum LoRA Experts method that dynamically evolves the MLLM's architecture with controlled parameter budgets to continually adapt to new tasks while retaining previously learned knowledge. D-MoLE features a dynamic layer-wise expert allocator and a gradient-based inter-modal continual curriculum.},
}

@inproceedings{Yu2024BoostingContinualLearningMoE,
  author    = {Yu, Jiazuo and Zhuge, Yunzhi and Zhang, Lu and Hu, Ping and Wang, Dong and Lu, Huchuan and He, You},
  title     = {Boosting Continual Learning of Vision-Language Models via Mixture-of-Experts Adapters},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
  pages     = {23219--23230},
  year      = {2024},
  doi       = {10.1109/CVPR52733.2024.02191},
  url       = {https://arxiv.org/abs/2403.11549},
  abstract  = {We present a parameter-efficient continual learning framework for vision-language models. Our approach involves the dynamic expansion of a pre-trained CLIP model through the integration of Mixture-of-Experts (MoE) adapters in response to new tasks. We further introduce a Distribution Discriminative Auto-Selector (DDAS) that automatically routes in-distribution and out-of-distribution inputs.},
}

@inproceedings{Wang2025MixtureLoRAExpertsEMNLP,
  author    = {Wang, Zitao and Wang, Xinyi and Hu, Wei},
  title     = {Mixture of {LoRA} Experts for Continual Information Extraction with {LLMs}},
  booktitle = {Findings of the Association for Computational Linguistics: EMNLP 2025},
  pages     = {13324--13339},
  year      = {2025},
  doi       = {10.18653/v1/2025.findings-emnlp.718},
  url       = {https://aclanthology.org/2025.findings-emnlp.718/},
  abstract  = {We propose a continual IE model using token-level mixture of LoRA experts with LLMs, employing a LoRA router to route each token to the most relevant LoRA experts, facilitating effective knowledge transfer among IE tasks. We further use task keys to retain IE task-specific knowledge and mitigate catastrophic forgetting.},
}

@misc{Araujo2024L2R,
  author    = {Araujo, Vladimir and Moens, Marie-Francine and Tuytelaars, Tinne},
  title     = {Learning to Route for Dynamic Adapter Composition in Continual Learning with Language Models},
  year      = {2024},
  doi       = {10.48550/arXiv.2408.09053},
  url       = {https://arxiv.org/abs/2408.09053},
  abstract  = {We present L2R, a method that isolates the training of new PEFT modules to ensure their task specialization. L2R then learns to compose the learned modules by training a network of routers that leverages a small memory containing examples of previously seen tasks. Our results demonstrate that L2R provides an effective composition of PEFT modules, leading to improved generalization and performance.},
}

% ============================================================
% THEME G: Gradient-Free / Training-Free CL
% ============================================================

@misc{Li2025JitRL,
  author       = {Li, Yibo and Lin, Zijie and Deng, Ailin and Zhang, Xuan and He, Yufei and Ji, Shuo and Cao, Tri and Hooi, Bryan},
  title        = {Just-In-Time Reinforcement Learning: Continual Learning in {LLM} Agents Without Gradient Updates},
  year         = {2025},
  doi          = {10.48550/ARXIV.2601.18510},
  url          = {https://arxiv.org/abs/2601.18510},
  abstract     = {JitRL enables LLM agents to continuously improve after deployment without gradient-based fine-tuning. JitRL employs a dynamic, non-parametric memory of experiences and retrieves relevant trajectories to estimate action advantages on-the-fly. These advantage estimates directly adjust the model's output logits without any weight updates, corresponding to the optimal solution for KL-constrained policy optimization.},
}

@misc{Wu2025AgentDice,
  author       = {Wu, Zheng and Lou, Xingyu and Ma, Xinbei and Li, Yansi and Liu, Weiwen and Zhang, Weinan and Wang, Jun and Zhang, Zhuosheng},
  title        = {Agent-Dice: Disentangling Knowledge Updates via Geometric Consensus for Agent Continual Learning},
  year         = {2025},
  doi          = {10.48550/ARXIV.2601.03641},
  url          = {https://arxiv.org/abs/2601.03641},
  abstract     = {Continual learning in LLM-based agents is hindered by the stability-plasticity dilemma. Agent-Dice is a parameter fusion framework based on directional consensus evaluation that operates in two phases: filtering out conflicting gradients through geometric consensus, and enhancing shared knowledge through curvature-based importance weighting.},
}

% ============================================================
% THEME H: Prompt-Based Methods
% ============================================================

@inproceedings{Razdaibiedina2023ProgressivePrompts,
  author    = {Anastasia Razdaibiedina and Yuning Mao and Rui Hou and Madian Khabsa and Mike Lewis and Amjad Almahairi},
  title     = {Progressive Prompts: Continual Learning for Language Models},
  booktitle = {Proceedings of the 11th International Conference on Learning Representations (ICLR)},
  year      = {2023},
  doi       = {10.48550/arXiv.2301.12314},
  url       = {https://arxiv.org/abs/2301.12314},
  abstract  = {We introduce Progressive Prompts --- a simple and efficient approach for continual learning in language models. Our method allows forward transfer and resists catastrophic forgetting, without relying on data replay or a large number of task-specific parameters. Progressive Prompts learns a new soft prompt for each task and sequentially concatenates it with the previously learned prompts, while keeping the base model frozen.},
}

@inproceedings{Wang2022L2P,
  author    = {Zifeng Wang and Zizhao Zhang and Chen-Yu Lee and Han Zhang and Ruoxi Sun and Xiaoqi Ren and Guolong Su and Vincent Perot and Jennifer Dy and Tomas Pfister},
  title     = {Learning to Prompt for Continual Learning},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  pages     = {139--149},
  year      = {2022},
  doi       = {10.1109/CVPR52688.2022.00024},
  url       = {https://arxiv.org/abs/2112.08654},
  abstract  = {This work presents a new paradigm for continual learning that aims to train a more succinct memory system without accessing task identity at test time. Our method learns to dynamically prompt (L2P) a pre-trained model to learn tasks sequentially under different task transitions. Prompts are small learnable parameters maintained in a memory space. L2P achieves competitive results against rehearsal-based methods even without a rehearsal buffer.},
}

% ============================================================
% THEME I: Memory-Augmented Methods
% ============================================================

@inproceedings{Wang2023LongMem,
  author    = {Wang, Weizhi and Dong, Li and Cheng, Hao and Liu, Xiaodong and Yan, Xifeng and Gao, Jianfeng and Wei, Furu},
  title     = {Augmenting Language Models with Long-Term Memory},
  booktitle = {Advances in Neural Information Processing Systems},
  volume    = {36},
  year      = {2023},
  doi       = {10.48550/ARXIV.2306.07174},
  url       = {https://arxiv.org/abs/2306.07174},
  abstract  = {We propose Language Models Augmented with Long-Term Memory (LongMem), which enables LLMs to memorize long history. We design a novel decoupled network architecture with the original backbone LLM frozen as a memory encoder and an adaptive residual side-network as a memory retriever and reader. LongMem can enlarge the long-form memory to 65k tokens and thus cache many-shot extra demonstration examples.},
}

@inproceedings{Fountas2025EMLLM,
  author    = {Fountas, Zafeirios and Benfeghoul, Martin A. and Oomerjee, Adnan and Christopoulou, Fenia and Lampouras, Gerasimos and Bou-Ammar, Haitham and Wang, Jun},
  title     = {Human-Inspired Episodic Memory for Infinite Context {LLMs}},
  booktitle = {Proceedings of the 13th International Conference on Learning Representations},
  year      = {2025},
  doi       = {10.48550/ARXIV.2407.09450},
  url       = {https://arxiv.org/abs/2407.09450},
  abstract  = {EM-LLM is a system inspired by human episodic memory that organises sequences of tokens into coherent episodic events using a combination of Bayesian surprise and graph-theoretic boundary refinement. It employs a two-stage memory process combining similarity-based and temporally contiguous retrieval. It succeeds at processing 10 million tokens---a scale infeasible for traditional full-context models.},
}

@misc{Ai2025MemoryBench,
  author       = {Ai, Qingyao and Tang, Yichen and Wang, Changyue and Long, Jianming and Su, Weihang and Liu, Yiqun},
  title        = {{MemoryBench}: A Benchmark for Memory and Continual Learning in {LLM} Systems},
  year         = {2025},
  doi          = {10.48550/ARXIV.2510.17281},
  url          = {https://arxiv.org/abs/2510.17281},
  abstract     = {MemoryBench is a benchmark for evaluating how well large language model systems can learn and retain information from accumulated user feedback during operation. A user feedback simulation framework and a comprehensive benchmark spanning multiple domains, languages, and task types are presented.},
}

% ============================================================
% THEME J: Cross-Field Analogues
% ============================================================

@article{Zhang2023NegativeTransfer,
  author    = {Zhang, Wen and Deng, Lingfei and Zhang, Lei and Wu, Dongrui},
  title     = {A Survey on Negative Transfer},
  journal   = {IEEE/CAA Journal of Automatica Sinica},
  year      = {2023},
  volume    = {10},
  number    = {2},
  pages     = {305--329},
  month     = feb,
  doi       = {10.1109/JAS.2022.106004},
  url       = {http://dx.doi.org/10.1109/JAS.2022.106004},
  abstract  = {Transfer learning (TL) utilizes data or knowledge from one or more source domains to facilitate learning in a target domain. Unfortunately, the effectiveness of TL is not always guaranteed. Negative transfer (NT), i.e., leveraging source domain data/knowledge undesirably reduces learning performance in the target domain, has been a long-standing and challenging problem. This paper reviews over fifty representative approaches for overcoming NT.},
}

@article{Holton2025Humans,
  author    = {Holton, Eleanor and Braun, Lukas and Thompson, Jessica AF and Grohn, Jan and Summerfield, Christopher},
  title     = {Humans and neural networks show similar patterns of transfer and interference during continual learning},
  journal   = {Nature Human Behaviour},
  year      = {2025},
  volume    = {10},
  number    = {1},
  pages     = {111--125},
  doi       = {10.1038/s41562-025-02318-y},
  url       = {http://dx.doi.org/10.1038/s41562-025-02318-y},
  abstract  = {Contrary to common claims, we show that humans demonstrate surprisingly similar patterns of interference as artificial neural networks. When learning sequential rule-based tasks, both learners benefit more from prior knowledge when tasks are similar---but as a result also exhibit greater interference when retested. These findings suggest that both biological and artificial learners follow shared computational principles relating transfer and interference, governed by task similarity and representational structure.},
}

@inproceedings{Zhang2023TARGET,
  author    = {Zhang, Jie and Chen, Chen and Zhuang, Weiming and Lv, Lingjuan},
  title     = {{TARGET}: Federated Class-Continual Learning via Exemplar-Free Distillation},
  booktitle = {Proceedings of the IEEE/CVF International Conference on Computer Vision (ICCV)},
  year      = {2023},
  doi       = {10.48550/arXiv.2303.06937},
  url       = {https://arxiv.org/abs/2303.06937},
  abstract  = {We first demonstrate that non-IID data exacerbates catastrophic forgetting in FL. Then we propose TARGET which alleviates catastrophic forgetting in FCCL while preserving client data privacy. Our method leverages the previously trained global model to transfer knowledge and a generator to produce synthetic data to simulate global distribution.},
}

@misc{Bakman2023FedOrth,
  author    = {Bakman, Yavuz Faruk and Yaldiz, Duygu Nur and Ezzeldin, Yahya H. and Avestimehr, Salman},
  title     = {Federated Orthogonal Training: Mitigating Global Catastrophic Forgetting in Continual Federated Learning},
  year      = {2023},
  doi       = {10.48550/arXiv.2309.01289},
  url       = {https://arxiv.org/abs/2309.01289},
  note      = {Accepted at ICLR 2024},
  abstract  = {The method extracts the global input subspace of each layer for old tasks and modifies the aggregated updates to maintain orthogonality with previous task representations, achieving up to 15\% accuracy gain with 27\% lower forgetting.}, % unverified: abstract paraphrased
}

@misc{Hamedi2025FedCL,
  author    = {Hamedi, Parisa and Razavi-Far, Roozbeh and Hallaji, Ehsan},
  title     = {Federated Continual Learning: Concepts, Challenges, and Solutions},
  year      = {2025},
  doi       = {10.48550/arXiv.2502.07059},
  url       = {https://arxiv.org/abs/2502.07059},
  note      = {Published also in Neurocomputing, vol. 651, 2025},
  abstract  = {Federated Continual Learning (FCL) has emerged as a robust solution for collaborative model training in dynamic environments. This survey addresses key challenges including heterogeneity, model stability, communication overhead, and privacy preservation.},
}

@article{Meng2025LEGION,
  author    = {Meng, Yuan and Bing, Zhenshan and Yao, Xiangtong and Chen, Kejia and Huang, Kai and Gao, Yang and Sun, Fuchun and Knoll, Alois},
  title     = {Preserving and combining knowledge in robotic lifelong reinforcement learning},
  journal   = {Nature Machine Intelligence},
  year      = {2025},
  volume    = {7},
  number    = {2},
  pages     = {256--269},
  doi       = {10.1038/s42256-025-00983-2},
  url       = {http://dx.doi.org/10.1038/s42256-025-00983-2},
  abstract  = {Our study introduces LEGION, a robotic lifelong reinforcement learning framework that incorporates a non-parametric Bayesian model into the knowledge space. Our agent can consistently accumulate knowledge from a continuous stream of one-time feeding tasks and tackle challenging real-world long-horizon tasks by combining and reapplying its acquired knowledge.},
}

@inproceedings{Liu2023LIBERO,
  author    = {Liu, Bo and Zhu, Yifeng and Gao, Chongkai and Feng, Yihao and Liu, Qian and Zhu, Yuke and Stone, Peter},
  title     = {{LIBERO}: Benchmarking Knowledge Transfer for Lifelong Robot Learning},
  booktitle = {Advances in Neural Information Processing Systems (NeurIPS)},
  year      = {2023},
  doi       = {10.48550/arXiv.2306.03310},
  url       = {https://arxiv.org/abs/2306.03310},
  abstract  = {We introduce LIBERO, a novel benchmark of lifelong learning for robot manipulation with 130 tasks across 4 suites. Key finding: sequential finetuning outperforms existing lifelong learning methods in forward transfer, no single visual encoder architecture excels at all types of knowledge transfer, and naive supervised pretraining can hinder agents' performance.},
}

@misc{Yang2024TaskAgnostic,
  author    = {Yang, Pengzhi and Wang, Xinyu and Zhang, Ruipeng and Wang, Cong and Oliehoek, Frans A. and Kober, Jens},
  title     = {Task-agnostic Lifelong Robot Learning with Retrieval-based Weighted Local Adaptation},
  year      = {2024},
  doi       = {10.48550/arXiv.2410.02995},
  url       = {https://arxiv.org/abs/2410.02995},
  abstract  = {Our method stores a subset of data from previous tasks and utilizes it for experience replay and a novel Retrieval-based Local Adaptation technique. A selective weighting mechanism focuses on the most forgotten skill segment. The method performs effectively in task-free scenarios without relying on task IDs or boundaries.},
}

@inproceedings{Ding2023ETR,
  author    = {Ding, Chuntao and Lu, Zhichao and Wang, Shangguang and Cheng, Ran and Boddeti, Vishnu Naresh},
  title     = {Mitigating Task Interference in Multi-Task Learning via Explicit Task Routing with Non-Learnable Primitives},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  year      = {2023},
  pages     = {7756--7765},
  doi       = {10.1109/CVPR52729.2023.00749},
  url       = {https://arxiv.org/abs/2308.02066},
  abstract  = {We propose ETR-NLP to mitigate task interference through non-learnable primitives (NLPs) that extract task-agnostic features and explicit task routing (ETR) that decouples shared and task-specific parameters. ETR-NLP significantly outperforms state-of-the-art baselines with fewer learnable parameters.},
}

@misc{Leng2024TaskNeurons,
  author    = {Leng, Yongqi and Xiong, Deyi},
  title     = {Towards Understanding Multi-Task Learning (Generalization) of {LLMs} via Detecting and Exploring Task-Specific Neurons},
  year      = {2024},
  doi       = {10.48550/arXiv.2407.06488},
  url       = {https://arxiv.org/abs/2407.06488},
  abstract  = {We identify task-sensitive neurons through gradient attribution and show that neuron overlap strongly associates with generalization performance. We propose a neuron-level continuous fine-tuning method targeting only current task-specific neurons, demonstrating effectiveness in mitigating catastrophic forgetting while maintaining performance.},
}

@misc{Wu2025ImbalancedGradients,
  author    = {Wu, Runzhe and Samanta, Ankur and Jain, Ayush and Fujimoto, Scott and Kwon, Jeongyeol and Kretzu, Ben and Yu, Youliang and Hassani, Kaveh and Vidolov, Boris and Efroni, Yonathan},
  title     = {Imbalanced Gradients in {RL} Post-Training of Multi-Task {LLMs}},
  year      = {2025},
  doi       = {10.48550/arXiv.2510.19178},
  url       = {https://arxiv.org/abs/2510.19178},
  abstract  = {We show that in RL post-training, certain tasks produce significantly larger gradients, biasing updates toward those tasks. Such gradient imbalance would be justified only if larger gradients implied larger learning gains---but we find this is not true. This cautions against naive dataset mixing and calls for principled gradient-level corrections.},
}

% ============================================================
% THEME K: Historical Foundations
% ============================================================

@incollection{McCloskey1989catastrophic,
  author    = {McCloskey, Michael and Cohen, Neal J.},
  title     = {Catastrophic Interference in Connectionist Networks: The Sequential Learning Problem},
  booktitle = {Psychology of Learning and Motivation},
  publisher = {Elsevier},
  year      = {1989},
  pages     = {109--165},
  doi       = {10.1016/s0079-7421(08)60536-8},
  url       = {https://doi.org/10.1016/s0079-7421(08)60536-8},
  abstract  = {This seminal chapter demonstrates that connectionist (neural network) models suffer from catastrophic interference when trained sequentially on multiple tasks: learning new associations causes rapid and near-total forgetting of previously learned associations.}, % unverified: abstract not available via open-access APIs
}

@article{Ratcliff1990connectionist,
  author    = {Ratcliff, Roger},
  title     = {Connectionist models of recognition memory: Constraints imposed by learning and forgetting functions},
  journal   = {Psychological Review},
  volume    = {97},
  number    = {2},
  pages     = {285--308},
  year      = {1990},
  doi       = {10.1037/0033-295x.97.2.285},
  url       = {https://doi.org/10.1037/0033-295x.97.2.285},
  abstract  = {This paper analyzes connectionist models of recognition memory and shows that standard backpropagation networks exhibit catastrophic interference: new learning rapidly overwrites old memories.}, % unverified: abstract not available via open-access APIs
}

@article{French1999catastrophic,
  author    = {French, Robert M.},
  title     = {Catastrophic forgetting in connectionist networks},
  journal   = {Trends in Cognitive Sciences},
  volume    = {3},
  number    = {4},
  pages     = {128--135},
  year      = {1999},
  month     = apr,
  doi       = {10.1016/s1364-6613(99)01294-2},
  url       = {https://doi.org/10.1016/s1364-6613(99)01294-2},
  abstract  = {This review article examines catastrophic forgetting in connectionist networks and surveys proposed solutions including activation sharpening, pseudo-rehearsal, and semi-distributed representations, drawing parallels with biological memory systems.}, % unverified: abstract not available via open-access APIs
}

@article{Li2018learning,
  author    = {Li, Zhizhong and Hoiem, Derek},
  title     = {Learning without Forgetting},
  journal   = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
  volume    = {40},
  number    = {12},
  pages     = {2935--2947},
  year      = {2018},
  month     = dec,
  doi       = {10.1109/tpami.2017.2773081},
  url       = {https://doi.org/10.1109/tpami.2017.2773081},
  abstract  = {We propose Learning without Forgetting, which uses only new task data to train the network while preserving the original capabilities via knowledge distillation. The method records the soft output predictions of the old model on new task inputs before training begins, then uses those outputs as a distillation target during training.},
}

@article{Rusu2016progressive,
  author    = {Rusu, Andrei A. and Rabinowitz, Neil C. and Desjardins, Guillaume and Soyer, Hubert and Kirkpatrick, James and Kavukcuoglu, Koray and Pascanu, Razvan and Hadsell, Raia},
  title     = {Progressive Neural Networks},
  journal   = {arXiv preprint arXiv:1606.04671},
  year      = {2016},
  url       = {https://arxiv.org/abs/1606.04671},
  abstract  = {Progressive networks are immune to forgetting and can leverage prior knowledge via lateral connections to previously learned features. Each new task receives its own dedicated neural network column, while all prior columns are frozen.},
}

@inproceedings{LopezPaz2017gradient,
  author    = {Lopez-Paz, David and Ranzato, Marc'Aurelio},
  title     = {Gradient Episodic Memory for Continual Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  year      = {2017},
  url       = {https://arxiv.org/abs/1706.08840},
  abstract  = {We propose Gradient Episodic Memory (GEM) that alleviates forgetting while allowing beneficial transfer of knowledge to previous tasks. GEM stores a small episodic memory and constrains gradient updates so performance on stored past examples cannot decrease.},
}

@inproceedings{Rebuffi2017icarl,
  author    = {Rebuffi, Sylvestre-Alvise and Kolesnikov, Alexander and Sperl, Georg and Lampert, Christoph H.},
  title     = {{iCaRL}: Incremental Classifier and Representation Learning},
  booktitle = {Proceedings of the IEEE Conference on Computer Vision and Pattern Recognition (CVPR)},
  year      = {2017},
  pages     = {2001--2010},
  doi       = {10.1109/CVPR.2017.587},
  url       = {https://arxiv.org/abs/1611.07725},
  abstract  = {iCaRL introduces exemplar-based class-incremental learning. It stores a fixed-budget set of representative exemplars per class selected via herding and uses nearest-mean-of-exemplars classification in feature space, combined with distillation and classification losses.},
}

@inproceedings{Mallya2018packnet,
  author    = {Mallya, Arun and Lazebnik, Svetlana},
  title     = {{PackNet}: Adding Multiple Tasks to a Single Network by Iterative Pruning},
  booktitle = {Proceedings of the IEEE Conference on Computer Vision and Pattern Recognition (CVPR)},
  year      = {2018},
  month     = jun,
  pages     = {7765--7773},
  doi       = {10.1109/cvpr.2018.00810},
  url       = {https://arxiv.org/abs/1711.05769},
  abstract  = {By performing iterative pruning and network re-training, we sequentially pack multiple tasks into a single network while ensuring minimal drop in performance. Unlike approaches that add extra parameters, our approach optimizes directly for the current task while freezing pruned weights from prior tasks.},
}

@inproceedings{Jin2022LifelongPretraining,
  author    = {Jin, Xisen and Zhang, Dejiao and Zhu, Henghui and Xiao, Wei and Li, Shang-Wen and Wei, Xiaokai and Arnold, Andrew and Ren, Xiang},
  title     = {Lifelong Pretraining: Continually Adapting Language Models to Emerging Corpora},
  booktitle = {Proceedings of the 2022 Conference of the North American Chapter of the Association for Computational Linguistics (NAACL)},
  year      = {2022},
  doi       = {10.48550/arXiv.2110.08534},
  url       = {https://arxiv.org/abs/2110.08534},
  abstract  = {We study a lifelong language model pretraining challenge where a PTLM is continually updated to adapt to emerging data. Over domain-incremental and chronologically-ordered streams, we show distillation-based approaches to be most effective in retaining downstream performance while also improving knowledge transfer.},
}

@misc{Luo2023CatastrophicForgettingLLM,
  author    = {Luo, Yun and Yang, Zhen and Meng, Fandong and Li, Yafu and Zhou, Jie and Zhang, Yue},
  title     = {An Empirical Study of Catastrophic Forgetting in Large Language Models During Continual Fine-tuning},
  year      = {2023},
  doi       = {10.48550/arXiv.2308.08747},
  url       = {https://arxiv.org/abs/2308.08747},
  abstract  = {This study empirically evaluates the forgetting phenomenon in LLMs ranging from 1b to 7b parameters. Surprisingly, as model scale increases, the severity of forgetting intensifies. The experiments reveal catastrophic forgetting in both factual knowledge and instruction-following alignment, introducing the distinction between true knowledge loss and alignment loss (spurious forgetting).},
}
