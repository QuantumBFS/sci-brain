% THEME B: LoRA / Adapter-Based Continual Learning
% ============================================================

@inproceedings{Wang2023OLoRA,
  author    = {Xiao Wang and Tianze Chen and Qiming Ge and Han Xia and Rong Bao and Rui Zheng and Qi Zhang and Tao Gui and Xuanjing Huang},
  title     = {Orthogonal Subspace Learning for Language Model Continual Learning},
  booktitle = {Findings of the Association for Computational Linguistics: EMNLP 2023},
  year      = {2023},
  doi       = {10.48550/arXiv.2310.14152},
  url       = {https://arxiv.org/abs/2310.14152},
  abstract  = {Benefiting from massive corpora and advanced hardware, large language models (LLMs) exhibit remarkable capabilities in language understanding and generation. However, their performance degrades in scenarios where multiple tasks are encountered sequentially, also known as catastrophic forgetting. In this paper, we propose orthogonal low-rank adaptation (O-LoRA), a simple and efficient approach for continual learning in language models, effectively mitigating catastrophic forgetting while learning new tasks. Specifically, O-LoRA learns tasks in different (low-rank) vector subspaces that are kept orthogonal to each other in order to minimize interference.},
}

@inproceedings{Liang2024InfLoRA,
  author    = {Yan-Shuo Liang and Wu-Jun Li},
  title     = {{InfLoRA}: Interference-Free Low-Rank Adaptation for Continual Learning},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  pages     = {23638--23647},
  year      = {2024},
  doi       = {10.48550/arXiv.2404.00228},
  url       = {https://arxiv.org/abs/2404.00228},
  abstract  = {Continual learning requires the model to learn multiple tasks sequentially. Recently, parameter-efficient fine-tuning (PEFT), which involves freezing a pre-trained model and injecting a small number of learnable parameters to adapt to downstream tasks, has gained increasing popularity in continual learning. In this work, we propose a new PEFT method, called interference-free low-rank adaptation (InfLoRA), for continual learning. InfLoRA injects a small number of parameters to reparameterize the pre-trained weights and shows that fine-tuning these injected parameters is equivalent to fine-tuning the pre-trained weights within a subspace. Furthermore, InfLoRA designs this subspace to eliminate the interference of the new task on the old tasks.},
}

@misc{Ren2024ILoRA,
  author    = {Weijieying Ren and Xinlong Li and Lei Wang and Tianxiang Zhao and Wei Qin},
  title     = {Analyzing and Reducing Catastrophic Forgetting in Parameter Efficient Tuning},
  year      = {2024},
  doi       = {10.48550/arXiv.2402.18865},
  url       = {https://arxiv.org/abs/2402.18865},
  abstract  = {Large language models suffer from catastrophic forgetting when continuously fine-tuned on new domain-specific tasks. We investigate this problem through the lens of mode connectivity, examining how different loss minima connect via low-loss valleys. Our findings indicate that mode connectivity can strike a balance between plasticity and stability. Based on this insight, we propose Interpolation-based LoRA (I-LoRA), which employs a dual-memory experience replay framework based on LoRA parameter interpolations. The method demonstrates substantial improvements across eight domain-specific continual learning benchmarks, achieving up to 11\% performance gains compared to previous approaches.},
}

@inproceedings{Qian2025TreeLoRA,
  author    = {Yu-Yang Qian and Yuan-Ze Xu and Zhen-Yu Zhang and Peng Zhao and Zhi-Hua Zhou},
  title     = {{TreeLoRA}: Efficient Continual Learning via Layer-Wise {LoRA}s Guided by a Hierarchical Gradient-Similarity Tree},
  booktitle = {Proceedings of the 42nd International Conference on Machine Learning (ICML)},
  year      = {2025},
  doi       = {10.48550/arXiv.2506.10355},
  url       = {https://arxiv.org/abs/2506.10355},
  abstract  = {We propose TreeLoRA, a method for efficient continual learning in large pre-trained models operating in streaming data environments where tasks arrive sequentially. TreeLoRA constructs layer-wise adapters by leveraging hierarchical gradient similarity to enable efficient continual learning, particularly for large pre-trained models.},
}

@misc{Wan2025OAAdapter,
  author    = {Zhiyi Wan and Wanrou Du and Liang Li and Miao Pan and Xiaoqi Qin},
  title     = {Adaptive Budget Allocation for Orthogonal-Subspace Adapter Tuning in {LLMs} Continual Learning},
  year      = {2025},
  doi       = {10.48550/arXiv.2505.22358},
  url       = {https://arxiv.org/abs/2505.22358},
  abstract  = {We propose OA-Adapter, which unifies dynamic budget adaptation with orthogonal subspace learning in an end-to-end training stage for continual learning in large language models. Key innovations include dynamic bottleneck dimension adaptation that allocates efficient parameter budgets while optimizing task objectives simultaneously, and orthogonal constraints applied between current and historical task parameter subspaces to preserve previously learned knowledge. OA-Adapter achieves higher average accuracy while using 58.5\% fewer parameters on the standard continual learning benchmark compared to existing methods.},
}

@inproceedings{Qiao2024LearnMore,
  author    = {Fuli Qiao and Mehrdad Mahdavi},
  title     = {Learn more, but bother less: parameter efficient continual learning},
  booktitle = {Advances in Neural Information Processing Systems (NeurIPS)},
  year      = {2024},
  url       = {https://proceedings.neurips.cc/paper_files/paper/2024/hash/b0bc711f48724237b38823c4d9cee10b-Abstract-Conference.html},
  abstract  = {We propose a parameter-efficient method for continual learning in large language models that addresses catastrophic forgetting during sequential task learning. Our approach employs sensitivity-based analysis of low-rank matrix parameters to identify knowledge-specific parameters between sequential tasks, using these to initialize parameters for new learning phases. To prevent interference with previously learned tasks, the method applies gradient projection techniques that keep the low-rank subspaces of each new task orthogonal to those of previous tasks.},
}

@inproceedings{Zhao2024SAPT,
  author    = {Weixiang Zhao and Shilong Wang and Yulin Hu and Yanyan Zhao and Bing Qin and Xuanyu Zhang and Qing Yang and Dongliang Xu and Wanxiang Che},
  title     = {{SAPT}: A Shared Attention Framework for Parameter-Efficient Continual Learning of Large Language Models},
  booktitle = {Proceedings of the 62nd Annual Meeting of the Association for Computational Linguistics (ACL)},
  pages     = {11641--11661},
  year      = {2024},
  doi       = {10.18653/v1/2024.acl-long.625},
  url       = {https://arxiv.org/abs/2401.08295},
  abstract  = {The continual learning (CL) ability is vital for deploying large language models (LLMs) in the dynamic world. Existing methods devise the learning module to acquire task-specific knowledge with parameter-efficient tuning (PET) block and the selection module to pick out the corresponding one for the testing input. We propose a novel Shared Attention Framework (SAPT), to align the PET learning and selection via the Shared Attentive Learning \& Selection module. Extensive experiments on two CL benchmarks demonstrate the superiority of SAPT.},
}

@misc{Kang2024SoftTF,
  author    = {Haeyong Kang and Chang D. Yoo},
  title     = {Soft-{TransFormers} for Continual Learning},
  year      = {2024},
  doi       = {10.48550/arXiv.2411.16073},
  url       = {https://arxiv.org/abs/2411.16073},
  abstract  = {We propose Soft-TransFormers (Soft-TF), a continual learning approach inspired by the Well-initialized Lottery Ticket Hypothesis. The method sequentially learns and selects an optimal soft-network for each task. During training, soft masks optimize weights in sparse layers while keeping pre-trained parameters frozen. At inference, these task-adaptive masks applied to pre-trained networks produce optimal solutions for each task while mitigating catastrophic forgetting.},
}

@inproceedings{Wang2024MoCL,
  author    = {Mingyang Wang and Heike Adel and Lukas Lange and Jannik Str{\"o}tgen and Hinrich Sch{\"u}tze},
  title     = {Rehearsal-Free Modular and Compositional Continual Learning for Language Models},
  booktitle = {Proceedings of the 2024 Conference of the North American Chapter of the Association for Computational Linguistics (NAACL), Volume 2: Short Papers},
  pages     = {469--480},
  year      = {2024},
  doi       = {10.18653/v1/2024.naacl-short.39},
  url       = {https://arxiv.org/abs/2404.00790},
  abstract  = {We propose MoCL, a rehearsal-free framework for continual learning in language models which continually adds new modules to language models and composes them with existing modules. Existing rehearsal-based methods raise privacy and memory concerns, while parameter-isolation methods do not consider interaction between tasks, hindering knowledge transfer. MoCL addresses both issues simultaneously.},
}

@inproceedings{Lu2025CLoRA,
  author    = {Yuheng Lu and Bingshuo Qian and Caixia Yuan and Huixing Jiang and Xiaojie Wang},
  title     = {Controlled Low-Rank Adaptation with Subspace Regularization for Continued Training on Large Language Models},
  booktitle = {Proceedings of the 63rd Annual Meeting of the Association for Computational Linguistics (ACL)},
  year      = {2025},
  doi       = {10.18653/v1/2025.acl-long.940},
  url       = {https://arxiv.org/abs/2410.16801},
  abstract  = {We present CLoRA, a subspace regularization method on LoRA structure that addresses catastrophic forgetting in large language models during continued training. CLoRA constrains the direction of the updating matrix's null space, reducing the scale of output change while introducing minimal constraint on model capacity. Experimental results on single-stage LLM fine-tuning tasks and continual learning settings highlight the superiority of CLoRA.},
}

% ============================================================
% THEME C: Replay & Rehearsal Methods
% ============================================================

@inproceedings{Rolnick2019ExperienceReplay,
  author    = {Rolnick, David and Ahuja, Arun and Schwarz, Jonathan and Lillicrap, Timothy and Wayne, Greg},
  title     = {Experience Replay for Continual Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  volume    = {32},
  year      = {2019},
  url       = {https://proceedings.neurips.cc/paper/2019/hash/fa7cdfad1a5aaf8370ebeda47a1ff1c3-Abstract.html},
  doi       = {10.48550/ARXIV.1811.11682},
  abstract  = {Interacting with a complex world involves continual learning, in which tasks and data distributions change over time. A continual learning system should demonstrate both plasticity (acquisition of new knowledge) and stability (preservation of old knowledge). Catastrophic forgetting is the failure of stability, in which new experience overwrites previous experience. Here, we introduce CLEAR, a replay-based method that greatly reduces catastrophic forgetting in multi-task reinforcement learning.},
}

@inproceedings{Huang2024SelfSynthesizedRehearsal,
  author    = {Huang, Jianheng and Cui, Leyang and Wang, Ante and Yang, Chengyi and Liao, Xinting and Song, Linfeng and Yao, Junfeng and Su, Jinsong},
  title     = {Mitigating Catastrophic Forgetting in Large Language Models with Self-Synthesized Rehearsal},
  booktitle = {Proceedings of the 62nd Annual Meeting of the Association for Computational Linguistics},
  year      = {2024},
  doi       = {10.48550/arXiv.2403.01244},
  url       = {https://arxiv.org/abs/2403.01244},
  abstract  = {Large language models (LLMs) suffer from catastrophic forgetting during continual learning. We propose a framework called Self-Synthesized Rehearsal (SSR) that uses the LLM to generate synthetic instances for rehearsal. Concretely, we first employ the base LLM for in-context learning to generate synthetic instances. Subsequently, we utilize the latest LLM to refine the instance outputs based on the synthetic inputs, preserving its acquired ability. Finally, we select diverse high-quality synthetic instances for rehearsal in future stages.},
}

@inproceedings{Liu2025ContextualExperienceReplay,
  author    = {Liu, Yitao and Si, Chenglei and Narasimhan, Karthik R. and Yao, Shunyu},
  title     = {Contextual Experience Replay for Continual Learning of Language Agents},
  booktitle = {Proceedings of the 13th International Conference on Learning Representations},
  year      = {2025},
  url       = {https://openreview.net/forum?id=RXvFK5dnpz},
  abstract  = {Language model-based agents face a key limitation in complex environments: they lack mechanisms for continual learning during inference without environment-specific experience. This paper proposes CER, a novel training-free framework to enable efficient continual learning for language agents through experience replay contextually in their context window. CER accumulates and synthesizes past experiences represented as natural language summarizations and concrete trajectory examples into a dynamic memory buffer. Evaluation on WebArena and VisualWebArena benchmarks shows a state-of-the-art success rate of 31.9\% on VisualWebArena.},
}

@misc{Hazard2025SuRe,
  author       = {Hazard, Hugo and Fountas, Zafeirios and Benfeghoul, Martin A. and Oomerjee, Adnan and Wang, Jun and Bou-Ammar, Haitham},
  title        = {{SuRe}: Surprise-Driven Prioritised Replay for Continual {LLM} Learning},
  year         = {2025},
  doi          = {10.48550/ARXIV.2511.22367},
  url          = {https://arxiv.org/abs/2511.22367},
  abstract     = {Continual learning for large language models faces two key failure modes: selection (determining what content to rehearse) and integration (consolidating new knowledge). SuRe (Surprise-driven Prioritised Replay) ranks and stores the most surprising (high Negative Log-Likelihood) sequences. For integration, a dual-learner design with fast and slow LoRA adapters merged via an exponential moving average (EMA) is introduced, enabling rapid adaptation while stabilising long-term knowledge.},
}

@article{Borhanifard2025ERILoRA,
  author  = {Borhanifard, Zeinab and Faili, Heshaam and Yaghoobzadeh, Yadollah},
  title   = {Combining Replay and {LoRA} for Continual Learning in Natural Language Understanding},
  journal = {Computer Speech \& Language},
  volume  = {90},
  pages   = {101737},
  year    = {2025},
  doi     = {10.1016/j.csl.2024.101737},
  url     = {https://www.sciencedirect.com/science/article/abs/pii/S0885230824001207},
  abstract = {This paper proposes Experience Replay Informative-Low Rank Adaptation (ERI-LoRA), a hybrid continual learning method for natural language understanding that combines replay-based methods with parameter-efficient fine-tuning via LoRA. ERI-LoRA selects a limited number of sample cases for experience replay based on class label distribution and fine-tunes LLaMA2 using LoRA with a small number of parameters.},
}

% ============================================================
% THEME D: Regularization & Loss-Landscape Methods
% ============================================================

@article{Kirkpatrick2017overcoming,
  author    = {Kirkpatrick, James and Pascanu, Razvan and Rabinowitz, Neil and Veness, Joel and Desjardins, Guillaume and Rusu, Andrei A. and Milan, Kieran and Quan, John and Ramalho, Tiago and Grabska-Barwinska, Agnieszka and Hassabis, Demis and Clopath, Claudia and Kumaran, Dharshan and Hadsell, Raia},
  title     = {Overcoming catastrophic forgetting in neural networks},
  journal   = {Proceedings of the National Academy of Sciences},
  volume    = {114},
  number    = {13},
  pages     = {3521--3526},
  year      = {2017},
  month     = mar,
  doi       = {10.1073/pnas.1611835114},
  url       = {https://doi.org/10.1073/pnas.1611835114},
  abstract  = {The ability to learn tasks in a sequential fashion is crucial to the development of artificial intelligence. Until now neural networks have not been capable of this and it has been widely thought that catastrophic forgetting is an inevitable feature of connectionist models. We show that it is possible to overcome this limitation and train networks that can maintain expertise on tasks that they have not experienced for a long time. Our approach remembers old tasks by selectively slowing down learning on the weights important for those tasks.},
}

@misc{Sliogeris2025EWCGemma2,
  author       = {{\v{S}}liogeris, Vytenis and Daniu{\v{s}}is, Povilas and Nakvosas, Art{\={u}}ras},
  title        = {Full-Parameter Continual Pretraining of {Gemma2}: Insights into Fluency and Domain Knowledge},
  year         = {2025},
  doi          = {10.48550/ARXIV.2505.05946},
  url          = {https://arxiv.org/abs/2505.05946},
  abstract     = {We empirically investigate the relationship between linguistic fluency and domain knowledge in the context of continual learning with large language models (LLMs). Specifically, we enhance the linguistic fluency of the Gemma2 LLM for the Lithuanian language by autoregressively pretraining its full parameter set. To prevent catastrophic forgetting, we apply Elastic Weight Consolidation (EWC), leveraging Fisher information estimated using data from MMLU. Results demonstrate that EWC not only mitigates catastrophic forgetting but also improves or maintains capabilities for the newly added language.},
}

@inproceedings{Li2024RevisitingCatastrophicForgetting,
  author    = {Li, Hongyu and Ding, Liang and Fang, Meng and Tao, Dacheng},
  title     = {Revisiting Catastrophic Forgetting in Large Language Model Tuning},
  booktitle = {Findings of the Association for Computational Linguistics: EMNLP 2024},
  year      = {2024},
  doi       = {10.48550/ARXIV.2406.04836},
  url       = {https://arxiv.org/abs/2406.04836},
  abstract  = {Catastrophic Forgetting (CF) compromises the effectiveness of large language models (LLMs) during fine-tuning, yet the underlying causes have not been thoroughly investigated. This paper reveals the direct link between the flatness of the model loss landscape and the extent of CF in LLMs. Based on this, we introduce sharpness-aware minimization to mitigate CF by flattening the loss landscape.},
}

% ============================================================
% THEME E: Model Merging
% ============================================================

@inproceedings{Ilharco2023TaskArithmetic,
  author    = {Ilharco, Gabriel and Ribeiro, Marco Tulio and Wortsman, Mitchell and Gururangan, Suchin and Schmidt, Ludwig and Hajishirzi, Hannaneh and Farhadi, Ali},
  title     = {Editing Models with Task Arithmetic},
  booktitle = {Proceedings of the 11th International Conference on Learning Representations},
  year      = {2023},
  doi       = {10.48550/ARXIV.2212.04089},
  url       = {https://arxiv.org/abs/2212.04089},
  abstract  = {We propose a new paradigm for steering the behavior of neural networks, centered around task vectors. A task vector specifies a direction in the weight space of a pre-trained model, such that movement in that direction improves performance on the task. We build task vectors by subtracting the weights of a pre-trained model from the weights of the same model after fine-tuning on a task. We show that these task vectors can be modified and combined together through arithmetic operations such as negation and addition, and the behavior of the resulting model is steered accordingly.},
}

@inproceedings{Alexandrov2024ModelMergingLanguageTransfer,
  author    = {Alexandrov, Anton and Raychev, Veselin and M{\"u}ller, Mark Niklas and Zhang, Ce and Vechev, Martin and Toutanova, Kristina},
  title     = {Mitigating Catastrophic Forgetting in Language Transfer via Model Merging},
  booktitle = {Findings of the Association for Computational Linguistics: EMNLP 2024},
  year      = {2024},
  doi       = {10.48550/ARXIV.2407.08699},
  url       = {https://arxiv.org/abs/2407.08699},
  abstract  = {We propose Branch-and-Merge (BaM), a new adaptation method based on iteratively merging multiple models, fine-tuned on a subset of the available training data. BaM is based on the insight that this yields lower magnitude but higher quality weight changes, reducing forgetting of the source domain while maintaining learning on the target domain.},
}

@inproceedings{Daheim2024ModelMergingGradient,
  author    = {Daheim, Nico and M{\"o}llenhoff, Thomas and Ponti, Edoardo Maria and Gurevych, Iryna and Khan, Mohammad Emtiyaz},
  title     = {Model Merging by Uncertainty-Based Gradient Matching},
  booktitle = {Proceedings of the 12th International Conference on Learning Representations},
  year      = {2024},
  doi       = {10.48550/ARXIV.2310.12808},
  url       = {https://arxiv.org/abs/2310.12808},
  abstract  = {Models trained on different datasets can be merged by a weighted-averaging of their parameters, but why does it work and when can it fail? Here, we connect the inaccuracy of weighted-averaging to mismatches in the gradients and propose a new uncertainty-based scheme to improve the performance by reducing the mismatch.},
}

